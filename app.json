{
  "expo": {
    "name": "Slick finance",
    "slug": "slick-finance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./appicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./appicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.budgetplanner.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.budgetplanner.app",
      "adaptiveIcon": {
        "backgroundColor": "#F4F4FF",
        "foregroundImage": "./appicon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./appicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-dev-client"
    ],
    "extra": {
      "eas": {
        "projectId": "492b80a9-3367-4429-9c71-0e14ffa3231b"
      }
    },
    "owner": "chavchuki",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/492b80a9-3367-4429-9c71-0e14ffa3231b"
    }
  }
}
