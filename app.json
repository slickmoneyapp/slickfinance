{
  "expo": {
    "name": "Slick Money",
    "slug": "slick-finance",
    "scheme": "slickfinance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./appicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aibudgetplanner.app",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.usernotifications.communication": true
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserActivityTypes": [
          "INSendMessageIntent"
        ]
      }
    },
    "android": {
      "package": "com.aibudgetplanner.app",
      "adaptiveIcon": {
        "backgroundColor": "#F4F4FF",
        "foregroundImage": "./appicon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./appicon.png"
    },
    "plugins": [
      "@bacons/apple-targets",
      "expo-font",
      "expo-dev-client",
      "expo-apple-authentication",
      "expo-web-browser",
      "react-native-adapty"
    ],
    "owner": "kazaka",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "04b307bf-2309-48e2-b76d-1f92d43de9f3"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/04b307bf-2309-48e2-b76d-1f92d43de9f3"
    }
  }
}
